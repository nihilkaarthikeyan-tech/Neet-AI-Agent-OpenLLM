# ──────────────────────────────────────────────────────────────
# NEET AI Open-Source — Production environment (Hostinger VPS)
# Copy to .env and fill in real values. NEVER commit the real .env.
#   cp .env.production.example .env && nano .env
# ──────────────────────────────────────────────────────────────

# ── Compose project (keeps containers separate from old neet-ai) ──
COMPOSE_PROJECT_NAME=neetollm

# ── URLs — set to your domain or VPS IP ──────────────────────
FRONTEND_URL=http://187.127.145.132:8090
BACKEND_URL=http://187.127.145.132:5006

# ── Ports (must not clash with existing containers on VPS) ────
FRONTEND_PORT=8090
BACKEND_PORT=5006
DB_PORT=5435

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=neet_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=neet_ai_openllm

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── Auth / JWT ────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_64char_random_string
REFRESH_SECRET=CHANGE_ME_64char_random_string
ADMIN_SECRET=CHANGE_ME_admin_panel_secret

# ── Open-source LLM (OpenRouter) ──────────────────────────────
LLM_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_OPENROUTER_KEY
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_TEXT=deepseek/deepseek-chat
LLM_MODEL_VISION=qwen/qwen2.5-vl-72b-instruct
LLM_MODEL_REASONING=deepseek/deepseek-r1
LLM_MODEL_TAMIL=deepseek/deepseek-chat

# ── Google OAuth (optional) ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email / SMTP (optional) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Observability (optional) ──────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
