generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  password   String
  role       String   @default("STUDENT") // "STUDENT" | "TEACHER"
  created_at DateTime @default(now())

  studyPlans         StudyPlan[]
  doubtHistory       DoubtMessage[]
  testAttempts       TestAttempt[]
  flashcards         Flashcard[]
  motivationMessages MotivationMessage[]
  weakAreaCache      WeakAreaCache?
}

model StudyPlan {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  examDate    DateTime
  weakSubjects String[]     // e.g. ["Physics", "Organic Chemistry"]
  planJson    Json          // full AI-generated schedule
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DoubtMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String   // "Physics" | "Chemistry" | "Biology"
  role      String   // "user" | "assistant"
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model TestAttempt {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String         // "Physics" | "Chemistry" | "Biology" | "Mixed"
  totalQ      Int
  score       Int?           // null until submitted
  timeTaken   Int?           // seconds elapsed, null until submitted
  submittedAt DateTime?
  createdAt   DateTime       @default(now())
  questions   TestQuestion[]
}

model TestQuestion {
  id            String      @id @default(uuid())
  attemptId     String
  attempt       TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  orderIndex    Int
  questionText  String      @db.Text
  optionA       String      @db.Text
  optionB       String      @db.Text
  optionC       String      @db.Text
  optionD       String      @db.Text
  correctOption String      // "A" | "B" | "C" | "D"
  explanation   String      @db.Text
  subject       String
  userAnswer    String?     // null until answered
}

model Flashcard {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  topic       String
  front       String   @db.Text
  back        String   @db.Text
  lastRating  String   @default("medium") // "easy" | "medium" | "hard"
  nextReview  DateTime @default(now())
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
}

model MotivationMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // "YYYY-MM-DD"
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model WeakAreaCache {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics      Json     // [{topic, subject, reason, accuracy}]
  generatedAt DateTime @default(now())
}

