# ──────────────────────────────────────────────────────────────
# NEET AI — backend environment template
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# ──────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5005
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5005

# ── Database (Postgres) ───────────────────────────────────────
# Used both directly and to compose DATABASE_URL in docker-compose.
POSTGRES_USER=neet_user
POSTGRES_PASSWORD=change-me-strong-secret
POSTGRES_DB=neet_ai
DATABASE_URL=postgresql://neet_user:change-me-strong-secret@localhost:5433/neet_ai
DB_POOL_MAX=15

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=change-me-redis-secret

# ── Auth / JWT ────────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret
REFRESH_SECRET=change-me-refresh-secret

# ── Open-source LLM provider ──────────────────────────────────
# OpenAI-compatible endpoint. Swap provider by changing these two lines only:
#   Together AI (testing/pilot): https://api.together.xyz/v1
#   Self-hosted vLLM (prod):     http://your-gpu-host:8000/v1
LLM_API_KEY=your-together-ai-key
LLM_BASE_URL=https://api.together.xyz/v1
# Text model — all text features (tutor, tests, quizzes, planner, flashcards, strategy, pyq, motivation)
LLM_MODEL_TEXT=deepseek-ai/DeepSeek-V3
# Vision model — Photo Doubt (set when switching off paid GPT-4o)
LLM_MODEL_VISION=Qwen/Qwen2.5-VL-72B-Instruct

# ── Photo Doubt fallback (optional) ───────────────────────────
# Only needed if Photo Doubt stays on paid GPT-4o instead of the open vision model.
OPENAI_API_KEY=

# ── Google OAuth (optional) ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email / SMTP (optional) ───────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── reCAPTCHA (optional) ──────────────────────────────────────
RECAPTCHA_SECRET_KEY=

# ── Observability (optional) ──────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
